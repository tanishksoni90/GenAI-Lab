// Prisma Schema for GenAI Lab
// Using SQLite for local development (easily migrated to other DBs)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== USERS ====================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("student") // student | admin
  registrationId String?  @unique
  
  // Password management
  mustChangePassword Boolean @default(false) // Force password change on next login
  
  // Account lockout (security)
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  
  // Student specific
  courseId      String?
  course        Course?   @relation(fields: [courseId], references: [id])
  batchId       String?
  batch         Batch?    @relation(fields: [batchId], references: [id])
  
  // Budget & Token management
  // All monetary values stored in USD (universal standard)
  // budgetLimit: USD budget limit (default $18 ≈ ₹1,500 @ 84 INR/USD)
  // budgetUsed: USD spent on API calls
  // tokenQuota: Virtual tokens for display (default 50,000)
  // tokenUsed: Virtual tokens used (calculated from budgetUsed)
  budgetLimit   Float     @default(18)    // USD budget limit
  budgetUsed    Float     @default(0)     // USD spent
  tokenQuota    Int       @default(50000) // Virtual display tokens
  tokenUsed     Int       @default(0)     // Virtual tokens used
  
  // Metadata
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  // Relations
  sessions      Session[]
  agents        Agent[]
  artifacts     Artifact[]
  activityLogs  ActivityLog[]
  comparisonSessions ComparisonSession[]
  
  @@index([email])
  @@index([registrationId])
  @@index([courseId])
  @@index([batchId])
  @@index([createdAt])
}

// ==================== COURSES & BATCHES ====================

model Course {
  id          String   @id @default(uuid())
  name        String
  description String?
  instructor  String?
  duration    Int?     // in weeks
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  batches     Batch[]
  students    User[]
  modelAccess ModelAccess[]
}

model Batch {
  id          String   @id @default(uuid())
  name        String
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  students    User[]
  modelAccess ModelAccess[]
  
  @@index([courseId])
}

// ==================== AI MODELS ====================

model AIModel {
  id          String   @id @default(uuid())
  name        String
  provider    String   // openai | google | anthropic | elevenlabs
  modelId     String   // gpt-4o, gemini-2.0-flash, etc.
  category    String   // text | image | audio | multimodal | code
  description String?
  
  // Pricing in USD (universal standard - as quoted by providers)
  // Primary pricing is in config/pricing.ts (per 1M tokens)
  // These DB fields are fallback/legacy (per 1K tokens)
  //
  // For text/code models: USD per 1K tokens
  // For image models: USD per image (in inputCost)
  // For audio models: USD per 1K characters (in inputCost)
  inputCost   Float    @default(0)  // USD per 1K input tokens
  outputCost  Float    @default(0)  // USD per 1K output tokens
  
  // Legacy INR fields (deprecated - keeping for backward compatibility)
  inputCostINR   Float    @default(0)  // Deprecated
  outputCostINR  Float    @default(0)  // Deprecated
  requestCostINR Float    @default(0)  // Deprecated
  
  // Configuration
  maxTokens   Int      @default(4096)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  sessions    Session[]
  agents      Agent[]
  modelAccess ModelAccess[]
  
  @@unique([provider, modelId])
}

model ModelAccess {
  id        String   @id @default(uuid())
  modelId   String
  model     AIModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  
  // Access can be at course, batch, or individual level
  courseId  String?
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  batchId   String?
  batch     Batch?   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  studentId String?  // registration ID for individual access
  
  createdAt DateTime @default(now())
  
  @@index([modelId])
  @@index([courseId])
  @@index([batchId])
}

// ==================== SESSIONS & MESSAGES ====================

model Session {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  modelId     String
  model       AIModel   @relation(fields: [modelId], references: [id])
  agentId     String?
  agent       Agent?    @relation(fields: [agentId], references: [id])
  
  title       String?
  
  // Scoring
  totalScore  Float     @default(0)
  avgScore    Float     @default(0)
  promptCount Int       @default(0)
  
  // Token usage (tracked separately for accurate costing)
  inputTokens  Int      @default(0)  // Total input tokens (prompts sent to model)
  outputTokens Int      @default(0)  // Total output tokens (model responses)
  tokensUsed   Int      @default(0)  // Total tokens (input + output) - for backward compat
  
  // Cost tracking in USD
  totalCost    Float    @default(0)  // Total USD cost for this session
  
  // Status
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  messages    Message[]
  artifacts   Artifact[]
  
  @@index([userId])
  @@index([modelId])
  @@index([agentId])
  @@index([createdAt])
  @@index([updatedAt])
}

model Message {
  id          String   @id @default(uuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  role        String   // user | assistant | system
  content     String
  
  // For user messages - prompt scoring
  score       Float?
  feedback    String?  // JSON string with detailed feedback
  
  // Token tracking (explicit for accurate costing)
  // For user messages: inputTokens = tokens sent to model
  // For assistant messages: outputTokens = tokens in response
  inputTokens  Int     @default(0)  // Input tokens (for user messages)
  outputTokens Int     @default(0)  // Output tokens (for assistant messages)
  tokens       Int     @default(0)  // Legacy field for backward compat
  
  // Cost in USD for this message
  cost         Float   @default(0)
  
  createdAt   DateTime @default(now())
  
  @@index([sessionId])
  @@index([createdAt])
}

// ==================== AI AGENTS ====================

model Agent {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  modelId         String
  model           AIModel  @relation(fields: [modelId], references: [id])
  
  name            String
  description     String?
  behaviorPrompt  String?
  strictMode      Boolean  @default(false)
  
  // Knowledge base files (JSON array of file paths)
  knowledgeBase   String?  // JSON array
  
  // Stats
  sessionsCount   Int      @default(0)
  messagesCount   Int      @default(0)
  tokensUsed      Int      @default(0)
  
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  sessions        Session[]
  guardrails      AgentGuardrail[]
  
  @@index([userId])
  @@index([modelId])
  @@index([createdAt])
}

model AgentGuardrail {
  id          String   @id @default(uuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  guardrailId String
  guardrail   Guardrail @relation(fields: [guardrailId], references: [id])
  
  @@unique([agentId, guardrailId])
}

// ==================== GUARDRAILS ====================

model Guardrail {
  id          String   @id @default(uuid())
  type        String   // educational_integrity | content_safety | behavioral_guidelines | custom
  title       String
  instruction String
  appliesTo   String   @default("both") // input | output | both
  priority    Int      @default(5)      // 1-10
  
  isSystem    Boolean  @default(false)  // System guardrails can't be deleted
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  agentGuardrails AgentGuardrail[]
}

// ==================== ARTIFACTS ====================

model Artifact {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  type        String   // text | code | image | audio
  title       String?
  content     String   // For text/code, actual content. For image/audio, file path
  
  // Metadata
  modelUsed   String?
  score       Float?
  
  isBookmarked Boolean @default(false)
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

// ==================== API KEYS (Admin managed) ====================

model APIKey {
  id        String   @id @default(uuid())
  provider  String   @unique // openai | google | anthropic | elevenlabs
  apiKey    String
  baseUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== ACTIVITY LOGS ====================

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  action    String   // login | session_start | prompt | agent_create | etc.
  details   String?  // JSON string with additional details
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([createdAt])
}

// ==================== MULTI-MODEL COMPARISON ====================

model ComparisonSession {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    String   // text | image | audio | video
  title       String?  // Auto-generated or user-defined
  
  // Token tracking (aggregated from all responses)
  totalInputTokens  Int   @default(0)  // Sum of all input tokens across models
  totalOutputTokens Int   @default(0)  // Sum of all output tokens across models
  totalTokensUsed   Int   @default(0)  // Total (legacy field)
  
  // Cost tracking in USD (sum of all model responses)
  totalCost         Float @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  exchanges   ComparisonExchange[]
  
  @@index([userId])
  @@index([category])
}

model ComparisonExchange {
  id                  String   @id @default(uuid())
  comparisonSessionId String
  comparisonSession   ComparisonSession @relation(fields: [comparisonSessionId], references: [id], onDelete: Cascade)
  
  prompt              String   // The shared prompt
  
  createdAt           DateTime @default(now())
  
  // Relations
  responses           ComparisonResponse[]
  
  @@index([comparisonSessionId])
}

model ComparisonResponse {
  id                    String   @id @default(uuid())
  comparisonExchangeId  String
  comparisonExchange    ComparisonExchange @relation(fields: [comparisonExchangeId], references: [id], onDelete: Cascade)
  
  modelId               String
  modelName             String   // Denormalized for quick access
  provider              String
  
  response              String
  
  // Token tracking (explicit for accurate costing)
  inputTokens           Int      @default(0)  // Tokens in the prompt sent to this model
  outputTokens          Int      @default(0)  // Tokens in this model's response
  tokensUsed            Int      @default(0)  // Total (legacy field)
  
  // Cost in USD for this response
  cost                  Float    @default(0)
  
  responseTimeMs        Int      @default(0) // Response time in milliseconds
  score                 Float?   // Optional prompt score
  isMock                Boolean  @default(false)
  error                 String?  // Error message if any
  
  createdAt             DateTime @default(now())
  
  @@index([comparisonExchangeId])
  @@index([modelId])
}

// ==================== SETTINGS ====================

model Settings {
  id                    String   @id @default("default")
  // Token Settings
  defaultTokenQuota     Int      @default(100000)
  autoRefill            Boolean  @default(false)
  lowBalanceAlert       Boolean  @default(false)
  hardLimitEnforcement  Boolean  @default(true)
  lowBalanceThreshold   Int      @default(10) // percentage
  // Guardrails Settings
  maxTokensPerRequest   Int      @default(2000)
  maxRequestsPerMinute  Int      @default(15)
  aiIntentDetection     Boolean  @default(true)
  strictMode            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

