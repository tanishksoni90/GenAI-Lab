# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# ==================== JWT SECRETS ====================
# REQUIRED IN PRODUCTION: Generate strong random strings
# The app will FAIL TO START in production if these contain default values
# Generate secure secrets: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ==================== ENCRYPTION KEY ====================
# REQUIRED IN PRODUCTION: 32-byte key for AES-256-GCM encryption of API keys
# Generate a secure key: openssl rand -hex 32
# WARNING: Changing this will make existing encrypted API keys unreadable!
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ==================== ADMIN REGISTRATION ====================
# REQUIRED: Secret code for admin registration (no default - must be set!)
# Generate a strong random string, e.g.: openssl rand -base64 32
ADMIN_REGISTRATION_CODE=your-secure-admin-code-here

# ==================== AI PROVIDER API KEYS ====================
# ⚠️ API KEYS ARE NOW MANAGED VIA ADMIN DASHBOARD
# 
# Go to Admin Dashboard → API Keys to configure your AI provider keys.
# The keys are securely stored in the database and used for all API calls.
# 
# Provider documentation for getting API keys:
# - OpenAI (GPT-4, GPT-4o, DALL-E): https://platform.openai.com/api-keys
# - Google AI (Gemini 2.0, 2.5): https://aistudio.google.com/apikey
# - Anthropic (Claude 4.5): https://console.anthropic.com/settings/keys
# - ElevenLabs (TTS): https://elevenlabs.io/app/speech-synthesis/api

# ==================== CORS ====================
# Frontend URL (for CORS - change in production)
FRONTEND_URL=http://localhost:8080

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

